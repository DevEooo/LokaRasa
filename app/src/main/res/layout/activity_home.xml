<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F2E8"
    tools:context=".Home">

    <!-- LOGO DI KIRI ATAS -->


    <ImageView
        android:id="@+id/headerImage"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/logoDesa"
        android:layout_width="60dp"
        android:layout_height="50dp"
        android:src="@drawable/lokarasa"
        android:background="@color/white"
        android:contentDescription="Logo Desa"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />

    <!-- JUDUL -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="UMKM\nDesa Lokarasa"
        android:textColor="@android:color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/headerImage"
        app:layout_constraintBottom_toBottomOf="@id/headerImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SAMBUTAN + FOTO KADES -->
    <TextView
        android:id="@+id/tvSambutanTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="“Selamat Datang di Website Desa Kami”"
        android:textColor="#00897B"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@id/headerImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/kepalaDesa"
        />

    <TextView
        android:id="@+id/tvSambutan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Kami senang Anda sudah berkunjung ke website desa kami, semoga melalui situs web ini kami dapat memberikan segala informasi yang aktual dan terperbarui langsung dari Desa kami..."
        android:textColor="#555"
        android:textSize="14sp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvSambutanTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/kepalaDesa"/>

    <ImageView
        android:id="@+id/kepalaDesa"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:src="@drawable/kbm"
        android:scaleType="fitCenter"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerImage"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SECTION JELAJAHI DESA -->
    <TextView
        android:id="@+id/tvJelajahi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JELAJAHI DESA"
        android:textStyle="bold"
        android:textColor="#333"
        android:textSize="18sp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/tvSambutan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvDeskripsiJelajahi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Melalui website ini Anda dapat menjelajahi segala hal yang terkait dengan Desa. Aspek pemerintahan, penduduk, demografi, potensi Desa, dan juga berita tentang Desa."
        android:textColor="#666"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_margin="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvJelajahi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- MENU PRODUK & ARTIKEL -->
    <LinearLayout
        android:id="@+id/menuContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvDeskripsiJelajahi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- PRODUK -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/deco3"
                android:contentDescription="Produk" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="our product"
                android:textColor="#333"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ARTIKEL -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center">

            <ImageView
                android:id="@+id/Article"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/deco4"
                android:contentDescription="Artikel" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="article"
                android:textColor="#333"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- BOTTOM MENU -->
    <LinearLayout
        android:id="@+id/bottomMenu"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#E6E2D3"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/menuContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Ikon 1 -->
        <ImageView
            android:id="@+id/FavIcons"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/deco6"
            android:contentDescription="Favorit" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:layout_marginHorizontal="16dp"
            android:background="#888888" />

        <!-- Ikon 2 -->
        <ImageView
            android:id="@+id/Homepage"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/home"
            android:contentDescription="Home" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:layout_marginHorizontal="16dp"
            android:background="#888888" />

        <!-- Ikon 3 -->
        <ImageView
            android:id="@+id/ShopIcons"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/shop"
            android:contentDescription="Shop" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:layout_marginHorizontal="16dp"
            android:background="#888888" />

        <!-- Ikon 4 -->
        <ImageView
            android:id="@+id/NotesIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/deco5"
            android:contentDescription="Catatan" />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
