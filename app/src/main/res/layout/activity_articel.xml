<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F2E8"
    tools:context=".Article">

    <ImageView
        android:id="@+id/headerImage"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/logoDesa"
        android:layout_width="60dp"
        android:layout_height="50dp"
        android:src="@drawable/lokarasa"
        android:background="@color/white"
        android:contentDescription="Logo Desa"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="BERITA DESA"
        android:textColor="@android:color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.486"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerImage" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:text="Menyajikan informasi terbaru tentang peristiwa,\nberita terkini, dan artikel-artikel jurnalistik\ndari Desa Sungai Besar"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <TextView
        android:id="@+id/tvBeritaTerkini"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="BERITA TERKINI"
        android:textColor="#333"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerImage" />

    <!-- CARD BERITA 1 -->

    <!-- CARD BERITA 2 -->

    <LinearLayout
        android:id="@+id/card1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:layout_marginTop="20dp"
        android:background="@color/hint_color"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBeritaTerkini">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pelatihan Digitalisasi Desa Bersama Pimpinan Lembaga Desa untuk Mewujudkan Desa yang Mandiri dan Berdaya Saing\n\nDengan adanya pelatihan ini, diharapkan seluruh perangkat desa dapat memaksimalkan teknologi digital..."
            android:textColor="#333"
            android:textSize="14sp" />

        <ImageView
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/berita1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/card2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/card1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    </LinearLayout>

    <!-- CARD BERITA 3 -->
    <LinearLayout
        android:id="@+id/card3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/cream_background"
        android:padding="12dp"
        android:layout_margin="12dp"
        app:layout_constraintTop_toBottomOf="@id/card2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pelajar Gelar Aksi Sosial dengan Membagikan Paket Sembako kepada Warga Desa\n\nKegiatan ini dilakukan secara langsung di lapangan dan disambut dengan antusias oleh masyarakat yang menerima bantuan. "
            android:textSize="14sp"
            android:textColor="#333"/>

        <ImageView
            android:layout_width="120dp"
            android:layout_height="100dp"
            android:src="@drawable/berita3"
            android:scaleType="centerCrop"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <!-- BOTTOM MENU -->
    <LinearLayout
        android:id="@+id/bottomMenu"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#E6E2D3"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Ikon 1 -->
        <ImageView
            android:id="@+id/FavIcons"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/deco6"
            android:contentDescription="Favorit" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:layout_marginHorizontal="16dp"
            android:background="#888888" />

        <!-- Ikon 2 -->
        <ImageView
            android:id="@+id/Homepage"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/home"
            android:contentDescription="Home" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:layout_marginHorizontal="16dp"
            android:background="#888888" />

        <!-- Ikon 3 -->
        <ImageView
            android:id="@+id/ShopIcons"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/shop"
            android:contentDescription="Shop" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:layout_marginHorizontal="16dp"
            android:background="#888888" />

        <!-- Ikon 4 -->
        <ImageView
            android:id="@+id/NotesIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/deco5"
            android:contentDescription="Catatan" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
